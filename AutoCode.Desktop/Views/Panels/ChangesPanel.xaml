<UserControl x:Class="AutoCode.Desktop.Views.Panels.ChangesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Self-contained review module: the active session's git changes + the Merge action
         (DataContext inherited — MainViewModel façade over the active WorkspaceSession). -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="14">
            <StackPanel>
                <TextBlock Text="{DynamicResource L_Changes}" Style="{StaticResource CapsLabel}" Margin="0,0,0,10"/>
                <ItemsControl ItemsSource="{Binding Changes}"/>
                <TextBlock Text="{DynamicResource L_NoChanges}" Foreground="{DynamicResource TextFaintBrush}" FontSize="13"
                           Visibility="{Binding HasChanges, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Merge bar — only for auto-branch (worktree) sessions. -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,1,0,0" Padding="14,10"
                Visibility="{Binding HasWorktree, Converter={StaticResource BoolToVis}}">
            <Button Style="{StaticResource SmallGhostButtonStyle}" Command="{Binding MergeCommand}"
                    HorizontalAlignment="Left" Content="{DynamicResource L_Merge}"/>
        </Border>
    </Grid>
</UserControl>
