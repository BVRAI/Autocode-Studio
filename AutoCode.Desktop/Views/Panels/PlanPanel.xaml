<UserControl x:Class="AutoCode.Desktop.Views.Panels.PlanPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Self-contained Plan module: the live todo checklist (DataContext inherited). -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
        <StackPanel>
            <TextBlock Text="{DynamicResource L_Plan}" Style="{StaticResource CapsLabel}" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding Plan}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
