<UserControl x:Class="AutoCode.Desktop.Views.Panels.WorkspacePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:AutoCode.Desktop.Controls">
    <!-- Self-contained side-panel module. DataContext is inherited (MainViewModel façade over the
         active WorkspaceSession). Behaviour lives in MainWindow via bound commands. -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
        <StackPanel>
            <TextBlock Text="{DynamicResource L_Session}" Style="{StaticResource CapsLabel}" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource L_Field_Id}" Foreground="{DynamicResource TextFaintBrush}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SessionId}" Foreground="{DynamicResource Text2Brush}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource L_Field_Model}" Margin="0,3,0,0" Foreground="{DynamicResource TextFaintBrush}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SessionModel}" Margin="0,3,0,0" Foreground="{DynamicResource Text2Brush}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource L_Field_Root}" Margin="0,3,0,0" Foreground="{DynamicResource TextFaintBrush}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SessionRoot}" Margin="0,3,0,0" Foreground="{DynamicResource Text2Brush}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" TextWrapping="Wrap"/>
            </Grid>

            <!-- git worktree branch (auto-branch mode) — the Merge action lives on the Changes tab. -->
            <Grid Margin="0,0,0,20" Visibility="{Binding HasWorktree, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource L_Branch}" Foreground="{DynamicResource TextFaintBrush}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="{Binding Branch}" Foreground="{DynamicResource GreenBrush}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" TextWrapping="Wrap"/>
            </Grid>

            <TextBlock Text="{DynamicResource L_Files}" Style="{StaticResource CapsLabel}" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding Files}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
