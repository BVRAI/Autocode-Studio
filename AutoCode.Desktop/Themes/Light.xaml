<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================== LIGHT THEME ===================== -->

    <!-- Title bar -->
    <SolidColorBrush x:Key="TitlebarBrush" Color="#efeeec"/>
    <SolidColorBrush x:Key="TitlebarTextBrush" Color="#45433f"/>

    <!-- Window body (behind the floating main-pane card) -->
    <SolidColorBrush x:Key="WindowBg" Color="#f3f2f0"/>

    <!-- Surfaces -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#ffffff"/>
    <SolidColorBrush x:Key="Surface2Brush" Color="#faf9f7"/>
    <SolidColorBrush x:Key="Surface3Brush" Color="#f3f1ee"/>
    <SolidColorBrush x:Key="Surface4Brush" Color="#ece9e4"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#0C22201C"/>
    <SolidColorBrush x:Key="HoverStrongBrush" Color="#1322201C"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush2" Color="#e7e4df"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#d8d4ce"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextBrush" Color="#232120"/>
    <SolidColorBrush x:Key="Text2Brush" Color="#56534e"/>
    <SolidColorBrush x:Key="Text3Brush" Color="#8a867f"/>
    <SolidColorBrush x:Key="TextFaintBrush" Color="#aaa59d"/>

    <!-- Bubbles / code -->
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#f1efec"/>
    <SolidColorBrush x:Key="CodeBgBrush" Color="#f1efeb"/>
    <SolidColorBrush x:Key="CodeTextBrush" Color="#3a3733"/>

    <!-- Accent (per-theme; light uses the design's #2f6fe0) -->
    <SolidColorBrush x:Key="AccentBrush" Color="#2f6fe0"/>
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#E6EEFB"/>
    <SolidColorBrush x:Key="AccentLineBrush" Color="#BCD1F5"/>
    <LinearGradientBrush x:Key="LogoChipBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2f6fe0" Offset="0"/>
        <GradientStop Color="#6d54e0" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="UsageBarFillBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#2f6fe0" Offset="0"/>
        <GradientStop Color="#6d54e0" Offset="1"/>
    </LinearGradientBrush>

    <!-- Semantic -->
    <SolidColorBrush x:Key="GreenBrush" Color="#1a7f47"/>
    <SolidColorBrush x:Key="GreenBgBrush" Color="#e7f4ec"/>
    <SolidColorBrush x:Key="RedBrush" Color="#c4453a"/>
    <SolidColorBrush x:Key="RedBgBrush" Color="#fbecea"/>
    <SolidColorBrush x:Key="AmberBrush" Color="#b06a14"/>
    <SolidColorBrush x:Key="AmberBgBrush" Color="#fdf2e2"/>
    <SolidColorBrush x:Key="AmberLineBrush" Color="#f0cf9a"/>
    <SolidColorBrush x:Key="AdminPillBorderBrush" Color="#EABEBA"/>
    <SolidColorBrush x:Key="DangerBorderBrush" Color="#EDC7C4"/>

    <!-- Scrim -->
    <SolidColorBrush x:Key="ScrimBrush" Color="#571C1A16"/>

</ResourceDictionary>
