<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ctl="clr-namespace:AutoCode.Desktop.Controls">

    <Style TargetType="{x:Type ctl:IconGlyph}">
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <!-- Foreground intentionally NOT set so icons inherit their parent (e.g. button) foreground. -->
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ctl:IconGlyph}">
                    <Viewbox Stretch="Uniform" SnapsToDevicePixels="True">
                        <Canvas Width="20" Height="20">
                            <Path x:Name="P"
                                  Data="{TemplateBinding Geometry}"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="{TemplateBinding StrokeThickness}"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="{x:Null}"/>
                        </Canvas>
                    </Viewbox>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Filled" Value="True">
                            <Setter TargetName="P" Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Setter TargetName="P" Property="Stroke" Value="{x:Null}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
