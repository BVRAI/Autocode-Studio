<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:AutoCode.Desktop.ViewModels"
                    xmlns:misc="clr-namespace:AutoCode.Desktop.Misc"
                    xmlns:ctl="clr-namespace:AutoCode.Desktop.Controls">

    <!-- ===================== assistant segments ===================== -->
    <DataTemplate DataType="{x:Type vm:ParagraphSegment}">
        <TextBlock misc:InlineBehavior.Markup="{Binding Markup}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   FontFamily="{DynamicResource UiFontFamily}"
                   FontSize="{DynamicResource BodyFontSize}"
                   LineHeight="23"
                   Foreground="{DynamicResource TextBrush}"/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:PathBlockSegment}">
        <Border Background="{DynamicResource Surface2Brush}" BorderBrush="{DynamicResource BorderBrush2}"
                BorderThickness="1" CornerRadius="8" Padding="12,9" Margin="0,0,0,12">
            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="12.5"
                       Foreground="{DynamicResource Text2Brush}"/>
        </Border>
    </DataTemplate>

    <!-- ===================== assistant message ===================== -->
    <DataTemplate DataType="{x:Type vm:AssistantBlock}">
        <StackPanel>
            <ItemsControl ItemsSource="{Binding Segments}"/>
            <StackPanel Orientation="Horizontal" Margin="-6,-2,0,0">
                <Button Style="{StaticResource ReactionButtonStyle}" ToolTip="Copy"
                        Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding Text}">
                    <ctl:IconGlyph Geometry="{StaticResource IconCopy}" Width="16" Height="16"/>
                </Button>
                <Button Style="{StaticResource ReactionButtonStyle}" ToolTip="Good response">
                    <ctl:IconGlyph Geometry="{StaticResource IconThumbUp}" Width="16" Height="16"/>
                </Button>
                <Button Style="{StaticResource ReactionButtonStyle}" ToolTip="Bad response">
                    <ctl:IconGlyph Geometry="{StaticResource IconThumbDown}" Width="16" Height="16"/>
                </Button>
                <Button Style="{StaticResource ReactionButtonStyle}" ToolTip="Share">
                    <ctl:IconGlyph Geometry="{StaticResource IconShare}" Width="16" Height="16"/>
                </Button>
            </StackPanel>
        </StackPanel>
    </DataTemplate>

    <!-- ===================== user bubble ===================== -->
    <DataTemplate DataType="{x:Type vm:UserBubbleBlock}">
        <Grid HorizontalAlignment="Stretch">
            <Border HorizontalAlignment="Right" MaxWidth="560"
                    Background="{DynamicResource UserBubbleBrush}" CornerRadius="16" Padding="15,11">
                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                           FontFamily="{DynamicResource UiFontFamily}" FontSize="{DynamicResource BodyFontSize}"
                           LineHeight="22" Foreground="{DynamicResource TextBrush}"/>
            </Border>
        </Grid>
    </DataTemplate>

    <!-- ===================== worked-for group ===================== -->
    <DataTemplate DataType="{x:Type vm:WorkedStep}">
        <Grid Margin="0,0,0,9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ctl:IconGlyph Grid.Column="0" Width="15" Height="15" Margin="0,1,9,0" VerticalAlignment="Top"
                           Geometry="{Binding Status, Converter={StaticResource StatusToGeometry}}"
                           Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
            <TextBlock Grid.Column="1" Text="{Binding Tool}" VerticalAlignment="Top" Margin="0,0,8,0"
                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="12"
                       Foreground="{DynamicResource TextBrush}"/>
            <TextBlock Grid.Column="2" Text="{Binding Detail}" TextWrapping="Wrap" VerticalAlignment="Top"
                       FontFamily="{DynamicResource UiFontFamily}" FontSize="12.5"
                       Foreground="{DynamicResource Text2Brush}"/>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:WorkedForBlock}">
        <StackPanel>
            <ToggleButton Style="{StaticResource WorkedToggleStyle}" IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                          HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <ctl:IconGlyph x:Name="Chev" Geometry="{StaticResource IconChevron}" Width="14" Height="14"
                                   Foreground="{DynamicResource TextFaintBrush}" Margin="0,0,7,0" VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5"/>
                    <ctl:IconGlyph Geometry="{StaticResource IconSpark}" Width="15" Height="15"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                </StackPanel>
            </ToggleButton>
            <Border Margin="7,3,0,0" Padding="16,0,0,0" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1.5,0,0,0"
                    Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{Binding Steps}" Margin="0,6,0,0"/>
            </Border>
        </StackPanel>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                <Setter TargetName="Chev" Property="RenderTransform">
                    <Setter.Value>
                        <RotateTransform Angle="90"/>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- ===================== diff card ===================== -->
    <DataTemplate DataType="{x:Type vm:DiffFileRow}">
        <Border BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,1,0,0" Padding="14,9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ctl:IconGlyph Grid.Column="0" Geometry="{StaticResource IconFile}" Width="15" Height="15"
                               Foreground="{DynamicResource Text3Brush}" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1" Text="{Binding Path}" TextTrimming="CharacterEllipsis"
                           FontFamily="{DynamicResource MonoFontFamily}" FontSize="12.5" Foreground="{DynamicResource Text2Brush}"/>
                <TextBlock Grid.Column="2" Text="{Binding CountsText}" FontFamily="{DynamicResource MonoFontFamily}"
                           FontSize="12" Foreground="{DynamicResource Text3Brush}"/>
            </Grid>
        </Border>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:DiffCardBlock}">
        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush2}"
                BorderThickness="1" CornerRadius="12">
            <StackPanel>
                <Grid Margin="14,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="30" Height="30" CornerRadius="8" Background="{DynamicResource Surface3Brush}" Margin="0,0,12,0">
                        <ctl:IconGlyph Geometry="{StaticResource IconDiff}" Width="16" Height="16" Foreground="{DynamicResource Text2Brush}"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" FontFamily="{DynamicResource UiFontFamily}" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding AddsText}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource GreenBrush}"/>
                            <TextBlock Text="{Binding DelsText}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource RedBrush}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButtonStyle}" ToolTip="Undo">
                            <StackPanel Orientation="Horizontal">
                                <ctl:IconGlyph Geometry="{StaticResource IconUndo}" Width="14" Height="14" Margin="0,0,5,0"/>
                                <TextBlock Text="Undo"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource GhostButtonStyle}" Margin="6,0,0,0" ToolTip="Review changes"
                                Command="{Binding DataContext.ReviewCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                            <StackPanel Orientation="Horizontal">
                                <ctl:IconGlyph Geometry="{StaticResource IconTerminal}" Width="14" Height="14" Margin="0,0,5,0"/>
                                <TextBlock Text="Review"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
                <ItemsControl ItemsSource="{Binding Files}"/>
            </StackPanel>
        </Border>
    </DataTemplate>

    <!-- ===================== notice ===================== -->
    <DataTemplate DataType="{x:Type vm:NoticeBlock}">
        <Border Background="{DynamicResource AmberBgBrush}" BorderBrush="{DynamicResource AmberLineBrush}"
                BorderThickness="1" CornerRadius="10" Padding="14,11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ctl:IconGlyph Grid.Column="0" Geometry="{StaticResource IconAlert}" Width="16" Height="16"
                               Foreground="{DynamicResource AmberBrush}" Margin="0,0,10,0" VerticalAlignment="Top"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Title}" FontFamily="{DynamicResource UiFontFamily}" FontSize="13"
                               FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Margin="0,2,0,0"
                               FontFamily="{DynamicResource UiFontFamily}" FontSize="12.5" Foreground="{DynamicResource Text2Brush}"
                               Visibility="{Binding Detail, Converter={StaticResource NullToVis}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- ===================== ecosystem member feed (design spec §2) ===================== -->
    <!-- One line inside a member turn card: a tool call (glyph + mono name + detail) or a message. -->
    <DataTemplate DataType="{x:Type vm:MemberTurnStep}">
        <Grid MinHeight="24" Margin="10,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ctl:IconGlyph x:Name="StepGlyph" Geometry="{StaticResource IconCode}" Width="12" Height="12"
                           Foreground="{DynamicResource Text3Brush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Ellipse x:Name="MsgDot" Width="4" Height="4" Fill="{DynamicResource TextFaintBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
            <TextBlock x:Name="StepTool" Grid.Column="1" Text="{Binding ToolName}" Margin="8,0,0,0"
                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource Text2Brush}" VerticalAlignment="Center"/>
            <TextBlock x:Name="StepDetail" Grid.Column="2" Text="{Binding Detail}" Margin="8,0,0,0"
                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource Text3Brush}"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding Detail}"/>
            <TextBlock x:Name="StepText" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Text}" Margin="8,0,0,0"
                       FontSize="12.5" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"
                       TextWrapping="Wrap" MaxHeight="36" ToolTip="{Binding Text}" Visibility="Collapsed"/>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsMessage}" Value="True">
                <Setter TargetName="StepGlyph" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="MsgDot" Property="Visibility" Value="Visible"/>
                <Setter TargetName="StepTool" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="StepDetail" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="StepText" Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding GlyphKey}" Value="IconFile">
                <Setter TargetName="StepGlyph" Property="Geometry" Value="{StaticResource IconFile}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding GlyphKey}" Value="IconTerminal">
                <Setter TargetName="StepGlyph" Property="Geometry" Value="{StaticResource IconTerminal}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding GlyphKey}" Value="IconSearch">
                <Setter TargetName="StepGlyph" Property="Geometry" Value="{StaticResource IconSearch}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding GlyphKey}" Value="IconGlobe">
                <Setter TargetName="StepGlyph" Property="Geometry" Value="{StaticResource IconGlobe}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding GlyphKey}" Value="IconCheck">
                <Setter TargetName="StepGlyph" Property="Geometry" Value="{StaticResource IconCheck}"/>
                <Setter TargetName="StepGlyph" Property="Foreground" Value="{DynamicResource GreenBrush}"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- Member turn card: header (chip + live status; pulsing amber while running) + step lines.
         Running shows the newest 3 with an "N earlier steps" expander; finished rests collapsed. -->
    <DataTemplate DataType="{x:Type vm:MemberTurnCardBlock}">
        <Border Background="{DynamicResource Surface2Brush}" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
                CornerRadius="10" Margin="0,0,64,-12" Padding="0,0,0,4">
            <StackPanel>
                <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}" Focusable="False" Cursor="Hand">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="Transparent" MinHeight="30" Padding="10,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ctl:IconGlyph x:Name="CollapseChev" Geometry="{StaticResource IconChevronDown}" Width="12" Height="12"
                                                   Margin="0,0,8,0" Foreground="{DynamicResource TextFaintBrush}" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    <Border Grid.Column="1" Background="{DynamicResource Surface4Brush}" CornerRadius="5" Padding="6,1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Member}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Text2Brush}"/>
                                    </Border>
                                    <Ellipse x:Name="PulseDot" Grid.Column="3" Width="6" Height="6" Margin="0,0,8,0" VerticalAlignment="Center"
                                             Fill="{DynamicResource AmberBrush}" Visibility="Collapsed"/>
                                    <TextBlock Grid.Column="4" Text="{Binding StatusText}" FontSize="11" Foreground="{DynamicResource TextFaintBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                    <Setter TargetName="CollapseChev" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter TargetName="PulseDot" Property="Visibility" Value="Visible"/>
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard x:Name="PulseSb">
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetName="PulseDot" Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0.4" Duration="0:0:0.6"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="PulseSb"/>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
                <ToggleButton x:Name="EarlierBtn" IsChecked="{Binding IsExpanded, Mode=TwoWay}" Focusable="False" Cursor="Hand" Visibility="Collapsed">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="Transparent" MinHeight="24" Padding="10,2">
                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="16">
                                        <ctl:IconGlyph Geometry="{StaticResource IconChevron}" Width="11" Height="11"
                                                       Foreground="{DynamicResource Text3Brush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Text="{Binding EarlierText}" Margin="8,0,0,0" FontSize="12"
                                               Foreground="{DynamicResource Text3Brush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
                <ItemsControl x:Name="RecentList" ItemsSource="{Binding VisibleSteps}" Visibility="Collapsed"/>
                <ItemsControl x:Name="FullList" ItemsSource="{Binding Steps}" Visibility="Collapsed"/>
            </StackPanel>
        </Border>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                <Setter TargetName="FullList" Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsExpanded}" Value="False"/>
                    <Condition Binding="{Binding IsRunning}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="RecentList" Property="Visibility" Value="Visible"/>
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsExpanded}" Value="False"/>
                    <Condition Binding="{Binding IsRunning}" Value="True"/>
                    <Condition Binding="{Binding HasEarlier}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="EarlierBtn" Property="Visibility" Value="Visible"/>
            </MultiDataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- Standalone feed rows: report (accent milestone card) / error (amber) / queued (ghost). -->
    <DataTemplate DataType="{x:Type vm:MemberActivityBlock}">
        <Grid Margin="0,0,64,-12">
            <Border x:Name="RepCard" Visibility="Collapsed" Background="{DynamicResource AccentSoftBrush}"
                    BorderBrush="{DynamicResource AccentLineBrush}" BorderThickness="1" CornerRadius="10" Padding="12,9">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ctl:IconGlyph Geometry="{StaticResource IconFlag}" Width="14" Height="14" Margin="0,0,8,0"
                                       Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="{DynamicResource Surface4Brush}" CornerRadius="5" Padding="6,1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Member}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Text2Brush}"/>
                        </Border>
                        <TextBlock Grid.Column="2" Text="{DynamicResource L_Feed_Report}" Margin="8,0,0,0" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="{Binding TimeText}" FontSize="11" Foreground="{DynamicResource TextFaintBrush}" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="{Binding Detail}" Margin="0,5,0,0" FontSize="13" LineHeight="19"
                               Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <Border x:Name="ErrCard" Visibility="Collapsed" Background="{DynamicResource AmberBgBrush}"
                    BorderBrush="{DynamicResource AmberLineBrush}" BorderThickness="1" CornerRadius="10" Padding="12,8">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ctl:IconGlyph Geometry="{StaticResource IconAlert}" Width="14" Height="14" Margin="0,0,8,0"
                                       Foreground="{DynamicResource AmberBrush}" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="{DynamicResource Surface4Brush}" CornerRadius="5" Padding="6,1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Member}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Text2Brush}"/>
                        </Border>
                        <TextBlock Grid.Column="2" Text="{Binding Summary}" Margin="8,0,0,0" FontSize="12.5" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="4" Text="{Binding TimeText}" FontSize="11" Foreground="{DynamicResource TextFaintBrush}" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="{Binding Detail}" Margin="0,4,0,0" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" LineHeight="17"
                               Foreground="{DynamicResource Text2Brush}" TextWrapping="Wrap" MaxHeight="51" ToolTip="{Binding Detail}"
                               Visibility="{Binding Detail, Converter={StaticResource NullToVis}}"/>
                </StackPanel>
            </Border>
            <Border x:Name="QueRow" Visibility="Collapsed" Background="Transparent"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" CornerRadius="8" Padding="10,5" MinHeight="26">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ctl:IconGlyph Geometry="{StaticResource IconDots}" Width="12" Height="12" Margin="0,0,8,0" Filled="True"
                                   Foreground="{DynamicResource Text3Brush}" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Background="{DynamicResource Surface4Brush}" CornerRadius="5" Padding="6,1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Member}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Text2Brush}"/>
                    </Border>
                    <TextBlock Grid.Column="2" Text="{Binding Summary}" Margin="8,0,0,0" FontSize="12"
                               Foreground="{DynamicResource Text3Brush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="{Binding Detail}" FontSize="11" Foreground="{DynamicResource TextFaintBrush}" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Kind}" Value="report">
                <Setter TargetName="RepCard" Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Kind}" Value="error">
                <Setter TargetName="ErrCard" Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Kind}" Value="queued">
                <Setter TargetName="QueRow" Property="Visibility" Value="Visible"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- ===================== working indicator ===================== -->
    <DataTemplate DataType="{x:Type vm:WorkingBlock}">
        <StackPanel Orientation="Horizontal">
            <ctl:IconGlyph x:Name="Spin" Geometry="{StaticResource IconSpinner}" Width="16" Height="16"
                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,9,0" RenderTransformOrigin="0.5,0.5">
                <ctl:IconGlyph.RenderTransform>
                    <RotateTransform x:Name="SpinRot" Angle="0"/>
                </ctl:IconGlyph.RenderTransform>
            </ctl:IconGlyph>
            <TextBlock Text="Working…" VerticalAlignment="Center" FontFamily="{DynamicResource UiFontFamily}"
                       FontSize="13" Foreground="{DynamicResource Text3Brush}"/>
        </StackPanel>
        <DataTemplate.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetName="SpinRot" Storyboard.TargetProperty="Angle"
                                         From="0" To="360" Duration="0:0:1"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

</ResourceDictionary>
