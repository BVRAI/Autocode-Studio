<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:AutoCode.Desktop.ViewModels"
                    xmlns:misc="clr-namespace:AutoCode.Desktop.Misc"
                    xmlns:ctl="clr-namespace:AutoCode.Desktop.Controls">

    <!-- ===================== assistant segments ===================== -->
    <DataTemplate DataType="{x:Type vm:ParagraphSegment}">
        <TextBlock misc:InlineBehavior.Markup="{Binding Markup}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   FontFamily="{DynamicResource UiFontFamily}"
                   FontSize="{DynamicResource BodyFontSize}"
                   LineHeight="23"
                   Foreground="{DynamicResource TextBrush}"/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:PathBlockSegment}">
        <Border Background="{DynamicResource Surface2Brush}" BorderBrush="{DynamicResource BorderBrush2}"
                BorderThickness="1" CornerRadius="8" Padding="12,9" Margin="0,0,0,12">
            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="12.5"
                       Foreground="{DynamicResource Text2Brush}"/>
        </Border>
    </DataTemplate>

    <!-- ===================== assistant message ===================== -->
    <DataTemplate DataType="{x:Type vm:AssistantBlock}">
        <StackPanel>
            <ItemsControl ItemsSource="{Binding Segments}"/>
            <StackPanel Orientation="Horizontal" Margin="-6,-2,0,0">
                <Button Style="{StaticResource ReactionButtonStyle}" ToolTip="Copy"
                        Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding Text}">
                    <ctl:IconGlyph Geometry="{StaticResource IconCopy}" Width="16" Height="16"/>
                </Button>
                <Button Style="{StaticResource ReactionButtonStyle}" ToolTip="Good response">
                    <ctl:IconGlyph Geometry="{StaticResource IconThumbUp}" Width="16" Height="16"/>
                </Button>
                <Button Style="{StaticResource ReactionButtonStyle}" ToolTip="Bad response">
                    <ctl:IconGlyph Geometry="{StaticResource IconThumbDown}" Width="16" Height="16"/>
                </Button>
                <Button Style="{StaticResource ReactionButtonStyle}" ToolTip="Share">
                    <ctl:IconGlyph Geometry="{StaticResource IconShare}" Width="16" Height="16"/>
                </Button>
            </StackPanel>
        </StackPanel>
    </DataTemplate>

    <!-- ===================== user bubble ===================== -->
    <DataTemplate DataType="{x:Type vm:UserBubbleBlock}">
        <Grid HorizontalAlignment="Stretch">
            <Border HorizontalAlignment="Right" MaxWidth="560"
                    Background="{DynamicResource UserBubbleBrush}" CornerRadius="16" Padding="15,11">
                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                           FontFamily="{DynamicResource UiFontFamily}" FontSize="{DynamicResource BodyFontSize}"
                           LineHeight="22" Foreground="{DynamicResource TextBrush}"/>
            </Border>
        </Grid>
    </DataTemplate>

    <!-- ===================== worked-for group ===================== -->
    <DataTemplate DataType="{x:Type vm:WorkedStep}">
        <Grid Margin="0,0,0,9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ctl:IconGlyph Grid.Column="0" Width="15" Height="15" Margin="0,1,9,0" VerticalAlignment="Top"
                           Geometry="{Binding Status, Converter={StaticResource StatusToGeometry}}"
                           Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
            <TextBlock Grid.Column="1" Text="{Binding Tool}" VerticalAlignment="Top" Margin="0,0,8,0"
                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="12"
                       Foreground="{DynamicResource TextBrush}"/>
            <TextBlock Grid.Column="2" Text="{Binding Detail}" TextWrapping="Wrap" VerticalAlignment="Top"
                       FontFamily="{DynamicResource UiFontFamily}" FontSize="12.5"
                       Foreground="{DynamicResource Text2Brush}"/>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:WorkedForBlock}">
        <StackPanel>
            <ToggleButton Style="{StaticResource WorkedToggleStyle}" IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                          HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <ctl:IconGlyph x:Name="Chev" Geometry="{StaticResource IconChevron}" Width="14" Height="14"
                                   Foreground="{DynamicResource TextFaintBrush}" Margin="0,0,7,0" VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5"/>
                    <ctl:IconGlyph Geometry="{StaticResource IconSpark}" Width="15" Height="15"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                </StackPanel>
            </ToggleButton>
            <Border Margin="7,3,0,0" Padding="16,0,0,0" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1.5,0,0,0"
                    Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{Binding Steps}" Margin="0,6,0,0"/>
            </Border>
        </StackPanel>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                <Setter TargetName="Chev" Property="RenderTransform">
                    <Setter.Value>
                        <RotateTransform Angle="90"/>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- ===================== diff card ===================== -->
    <DataTemplate DataType="{x:Type vm:DiffFileRow}">
        <Border BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,1,0,0" Padding="14,9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ctl:IconGlyph Grid.Column="0" Geometry="{StaticResource IconFile}" Width="15" Height="15"
                               Foreground="{DynamicResource Text3Brush}" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1" Text="{Binding Path}" TextTrimming="CharacterEllipsis"
                           FontFamily="{DynamicResource MonoFontFamily}" FontSize="12.5" Foreground="{DynamicResource Text2Brush}"/>
                <TextBlock Grid.Column="2" Text="{Binding CountsText}" FontFamily="{DynamicResource MonoFontFamily}"
                           FontSize="12" Foreground="{DynamicResource Text3Brush}"/>
            </Grid>
        </Border>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:DiffCardBlock}">
        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush2}"
                BorderThickness="1" CornerRadius="12">
            <StackPanel>
                <Grid Margin="14,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="30" Height="30" CornerRadius="8" Background="{DynamicResource Surface3Brush}" Margin="0,0,12,0">
                        <ctl:IconGlyph Geometry="{StaticResource IconDiff}" Width="16" Height="16" Foreground="{DynamicResource Text2Brush}"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" FontFamily="{DynamicResource UiFontFamily}" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding AddsText}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource GreenBrush}"/>
                            <TextBlock Text="{Binding DelsText}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource RedBrush}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButtonStyle}" ToolTip="Undo">
                            <StackPanel Orientation="Horizontal">
                                <ctl:IconGlyph Geometry="{StaticResource IconUndo}" Width="14" Height="14" Margin="0,0,5,0"/>
                                <TextBlock Text="Undo"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource GhostButtonStyle}" Margin="6,0,0,0" ToolTip="Review changes"
                                Command="{Binding DataContext.ReviewCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                            <StackPanel Orientation="Horizontal">
                                <ctl:IconGlyph Geometry="{StaticResource IconTerminal}" Width="14" Height="14" Margin="0,0,5,0"/>
                                <TextBlock Text="Review"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
                <ItemsControl ItemsSource="{Binding Files}"/>
            </StackPanel>
        </Border>
    </DataTemplate>

    <!-- ===================== notice ===================== -->
    <DataTemplate DataType="{x:Type vm:NoticeBlock}">
        <Border Background="{DynamicResource AmberBgBrush}" BorderBrush="{DynamicResource AmberLineBrush}"
                BorderThickness="1" CornerRadius="10" Padding="14,11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ctl:IconGlyph Grid.Column="0" Geometry="{StaticResource IconAlert}" Width="16" Height="16"
                               Foreground="{DynamicResource AmberBrush}" Margin="0,0,10,0" VerticalAlignment="Top"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Title}" FontFamily="{DynamicResource UiFontFamily}" FontSize="13"
                               FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Margin="0,2,0,0"
                               FontFamily="{DynamicResource UiFontFamily}" FontSize="12.5" Foreground="{DynamicResource Text2Brush}"
                               Visibility="{Binding Detail, Converter={StaticResource NullToVis}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- ===================== ecosystem member activity (feed) ===================== -->
    <!-- Attributed activity teed from a member session into the ecosystem chat. Stage-B minimal;
         design pass #2 restyles (per-Kind accents, chip treatment). -->
    <DataTemplate DataType="{x:Type vm:MemberActivityBlock}">
        <Border Background="{DynamicResource Surface3Brush}" BorderBrush="{DynamicResource BorderBrush2}"
                BorderThickness="2,0,0,0" CornerRadius="4" Padding="10,6" Margin="0,0,64,0">
            <StackPanel Orientation="Horizontal">
                <Border Background="{DynamicResource Surface4Brush}" CornerRadius="5" Padding="6,1" Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Member}" FontFamily="{DynamicResource UiFontFamily}" FontSize="11"
                               FontWeight="SemiBold" Foreground="{DynamicResource Text2Brush}"/>
                </Border>
                <TextBlock Text="{Binding Summary}" FontFamily="{DynamicResource UiFontFamily}" FontSize="12.5"
                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding Detail}" FontFamily="{DynamicResource UiFontFamily}" FontSize="12"
                           Foreground="{DynamicResource Text3Brush}" Margin="7,0,0,0" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Visibility="{Binding Detail, Converter={StaticResource NullToVis}}"/>
            </StackPanel>
        </Border>
    </DataTemplate>

    <!-- ===================== working indicator ===================== -->
    <DataTemplate DataType="{x:Type vm:WorkingBlock}">
        <StackPanel Orientation="Horizontal">
            <ctl:IconGlyph x:Name="Spin" Geometry="{StaticResource IconSpinner}" Width="16" Height="16"
                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,9,0" RenderTransformOrigin="0.5,0.5">
                <ctl:IconGlyph.RenderTransform>
                    <RotateTransform x:Name="SpinRot" Angle="0"/>
                </ctl:IconGlyph.RenderTransform>
            </ctl:IconGlyph>
            <TextBlock Text="Working…" VerticalAlignment="Center" FontFamily="{DynamicResource UiFontFamily}"
                       FontSize="13" Foreground="{DynamicResource Text3Brush}"/>
        </StackPanel>
        <DataTemplate.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetName="SpinRot" Storyboard.TargetProperty="Angle"
                                         From="0" To="360" Duration="0:0:1"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

</ResourceDictionary>
