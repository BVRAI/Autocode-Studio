<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:AutoCode.Desktop.ViewModels"
                    xmlns:ctl="clr-namespace:AutoCode.Desktop.Controls">

    <!-- ===================== tool timeline card ===================== -->
    <DataTemplate DataType="{x:Type vm:TimelineItemVM}">
        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush2}"
                BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,0,8">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="18" Height="18" CornerRadius="9" Margin="0,0,9,0"
                            Background="{Binding Status, Converter={StaticResource StatusToBrush}, ConverterParameter=bg}">
                        <ctl:IconGlyph x:Name="StIcon" Width="11" Height="11" RenderTransformOrigin="0.5,0.5"
                                       Geometry="{Binding Status, Converter={StaticResource StatusToGeometry}}"
                                       Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}">
                            <ctl:IconGlyph.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </ctl:IconGlyph.RenderTransform>
                        </ctl:IconGlyph>
                    </Border>
                    <TextBlock Grid.Column="1" Text="{Binding ToolName}" VerticalAlignment="Center"
                               FontFamily="{DynamicResource MonoFontFamily}" FontSize="12.5" FontWeight="Medium"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Grid.Column="3" VerticalAlignment="Center"
                               Text="{Binding DurationMs, Converter={StaticResource DurationToText}}"
                               FontFamily="{DynamicResource MonoFontFamily}" FontSize="11.5" Foreground="{DynamicResource TextFaintBrush}"/>
                </Grid>
                <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" Margin="0,6,0,0"
                           FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource Text2Brush}"
                           Visibility="{Binding Summary, Converter={StaticResource NullToVis}}"/>
            </StackPanel>
        </Border>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Status}" Value="running">
                <DataTrigger.EnterActions>
                    <BeginStoryboard Name="SpinSb">
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="StIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                             From="0" To="360" Duration="0:0:1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="SpinSb"/>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- ===================== approval preview line ===================== -->
    <DataTemplate DataType="{x:Type vm:PreviewLine}">
        <TextBlock x:Name="L" Text="{Binding Text}" TextWrapping="Wrap"
                   FontFamily="{DynamicResource MonoFontFamily}" FontSize="12"
                   Foreground="{DynamicResource Text3Brush}"/>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Kind}" Value="add">
                <Setter TargetName="L" Property="Foreground" Value="{DynamicResource GreenBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Kind}" Value="del">
                <Setter TargetName="L" Property="Foreground" Value="{DynamicResource RedBrush}"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- ===================== plan / todo checklist row ===================== -->
    <DataTemplate DataType="{x:Type vm:PlanItemVM}">
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ctl:IconGlyph x:Name="PIcon" Grid.Column="0" Width="15" Height="15" Margin="0,1,10,0" VerticalAlignment="Top"
                           Geometry="{StaticResource IconCircle}" Foreground="{DynamicResource TextFaintBrush}"/>
            <TextBlock x:Name="PText" Grid.Column="1" Text="{Binding Text}" TextWrapping="Wrap"
                       FontSize="13" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Status}" Value="in_progress">
                <Setter TargetName="PIcon" Property="Geometry" Value="{StaticResource IconSpinner}"/>
                <Setter TargetName="PIcon" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                <Setter TargetName="PText" Property="FontWeight" Value="SemiBold"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="completed">
                <Setter TargetName="PIcon" Property="Geometry" Value="{StaticResource IconCheck}"/>
                <Setter TargetName="PIcon" Property="Foreground" Value="{DynamicResource GreenBrush}"/>
                <Setter TargetName="PText" Property="Foreground" Value="{DynamicResource TextFaintBrush}"/>
                <Setter TargetName="PText" Property="TextDecorations" Value="Strikethrough"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="interrupted">
                <Setter TargetName="PIcon" Property="Geometry" Value="{StaticResource IconAlert}"/>
                <Setter TargetName="PIcon" Property="Foreground" Value="{DynamicResource AmberBrush}"/>
                <Setter TargetName="PText" Property="Foreground" Value="{DynamicResource Text2Brush}"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- ===================== changed-file row (review tab) ===================== -->
    <DataTemplate DataType="{x:Type vm:ChangeItem}">
        <Grid Margin="0,0,0,7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="Badge" Grid.Column="0" Text="{Binding Status}" VerticalAlignment="Top" Margin="0,1,8,0"
                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" FontWeight="Bold"
                       Foreground="{DynamicResource AmberBrush}"/>
            <TextBlock Grid.Column="1" Text="{Binding Path}" TextWrapping="Wrap"
                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="12.5" Foreground="{DynamicResource Text2Brush}"/>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Status}" Value="A">
                <Setter TargetName="Badge" Property="Foreground" Value="{DynamicResource GreenBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="D">
                <Setter TargetName="Badge" Property="Foreground" Value="{DynamicResource RedBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="R">
                <Setter TargetName="Badge" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- ===================== file tree row ===================== -->
    <DataTemplate DataType="{x:Type vm:FileNode}">
        <Button Style="{StaticResource TreeRowStyle}"
                Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                CommandParameter="{Binding}">
            <StackPanel Orientation="Horizontal">
                <Border Width="{Binding Indent}"/>
                <ctl:IconGlyph x:Name="Ic" Width="14" Height="14" Margin="0,0,7,0" VerticalAlignment="Center"
                               Geometry="{StaticResource IconFile}" Foreground="{DynamicResource Text3Brush}"/>
                <TextBlock x:Name="Nm" Text="{Binding Name}" VerticalAlignment="Center"
                           FontFamily="{DynamicResource MonoFontFamily}" FontSize="12.5" Foreground="{DynamicResource Text2Brush}"/>
                <TextBlock x:Name="Mod" Text="M" Margin="7,0,0,0" VerticalAlignment="Center"
                           FontFamily="{DynamicResource MonoFontFamily}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource AmberBrush}" Visibility="Collapsed"/>
            </StackPanel>
        </Button>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                <Setter TargetName="Ic" Property="Geometry" Value="{StaticResource IconFolder}"/>
                <Setter TargetName="Ic" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                <Setter TargetName="Nm" Property="Foreground" Value="{DynamicResource TextBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsModified}" Value="True">
                <Setter TargetName="Mod" Property="Visibility" Value="Visible"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

</ResourceDictionary>
